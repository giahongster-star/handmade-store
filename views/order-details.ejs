<%- include('partials/header') %>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  
  <!-- Success Banner -->
  <div class="bg-white border border-[#EAE6DF] rounded-3xl p-8 sm:p-12 shadow-sm text-center mb-8">
    <div class="inline-flex items-center justify-center h-16 w-16 rounded-full bg-green-50 text-green-600 mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" strokeWidth={2} stroke="currentColor" class="w-8 h-8">
        <path strokeLinecap="round" strokeLinejoin="round" d="m4.5 12.75 6 6 9-13.5" />
      </svg>
    </div>
    
    <h1 class="font-serif text-3xl font-bold text-[#1A1918] mb-3">Đặt Hàng Thành Công!</h1>
    <p class="text-sm text-[#5C5752] leading-relaxed max-w-md mx-auto font-light">
      Cảm ơn bạn đã tin tưởng AuraCraft. Đơn hàng của bạn đang được hệ thống xử lý và sẽ sớm được giao tới địa chỉ của bạn.
    </p>
  </div>

  <!-- Order Info Card -->
  <div class="bg-white border border-[#EAE6DF] rounded-3xl p-8 sm:p-10 shadow-sm space-y-8 mb-8">
    <!-- Invoice Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between pb-6 border-b border-[#F2EFE9] space-y-4 sm:space-y-0">
      <div>
        <p class="text-xs uppercase tracking-wider text-[#8C867E] font-semibold mb-1">Mã Đơn Hàng</p>
        <p class="text-lg font-bold text-[#1A1918] font-mono"><%= order.code %></p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-wider text-[#8C867E] font-semibold mb-1">Thời gian đặt</p>
        <p class="text-sm font-medium text-[#2C2A29]"><%= new Date(order.created_at).toLocaleString('vi-VN') %></p>
      </div>
    </div>

    <!-- Delivery Details -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 pb-6 border-b border-[#F2EFE9]">
      <div>
        <h3 class="text-xs uppercase tracking-wider text-[#8C867E] font-semibold mb-2">Địa Chỉ Giao Hàng</h3>
        <p class="text-sm text-[#2C2A29] font-medium leading-relaxed">
          <%= order.shipping_address %>
        </p>
      </div>
      <div>
        <h3 class="text-xs uppercase tracking-wider text-[#8C867E] font-semibold mb-2">Phương thức thanh toán</h3>
        <p class="text-sm text-[#2C2A29] font-medium capitalize">
          <%= order.payment_method === 'cod' ? 'Thanh toán khi nhận hàng (COD)' : 'Chuyển khoản ngân hàng' %>
        </p>
        <p class="text-xs text-[#8C867E] mt-1.5 capitalize">Trạng thái: <%= order.payment_status === 'unpaid' ? 'Chưa thanh toán' : 'Đã thanh toán' %></p>
      </div>
    </div>

    <!-- Items Table -->
    <div>
      <h3 class="text-xs uppercase tracking-wider text-[#8C867E] font-semibold mb-4">Danh sách sản phẩm</h3>
      <div class="space-y-4">
        <% items.forEach(function(item) { %>
          <div class="flex items-center justify-between py-2.5">
            <div class="flex items-center space-x-3">
              <div class="w-12 h-12 rounded-lg bg-[#FAF9F6] overflow-hidden border border-[#EAE6DF] flex-shrink-0">
                <img src="<%= item.primary_image_url || 'https://images.unsplash.com/photo-1531403009284-440f080d1e12?auto=format&fit=crop&w=100&q=80' %>" alt="<%= item.name %>" class="w-full h-full object-cover" />
              </div>
              <div>
                <a href="/product/<%= item.slug %>" class="text-sm font-bold text-[#1A1918] hover:text-[#D4A373] transition line-clamp-1">
                  <%= item.name %>
                </a>
                <span class="text-xs text-[#8C867E]">Số lượng: <%= item.quantity %></span>
              </div>
            </div>
            <span class="text-sm font-bold text-[#1A1918]">
              <%= formatPrice(item.price * item.quantity) %>
            </span>
          </div>
        <% }); %>
      </div>
    </div>

    <!-- Billing summary -->
    <div class="border-t border-[#F2EFE9] pt-6 space-y-3">
      <div class="flex justify-between text-sm">
        <span class="text-[#8C867E]">Tạm tính:</span>
        <span class="font-semibold text-[#1A1918]"><%= formatPrice(order.total_amount - order.shipping_fee) %></span>
      </div>
      <div class="flex justify-between text-sm">
        <span class="text-[#8C867E]">Phí vận chuyển:</span>
        <span class="font-semibold text-[#1A1918]"><%= formatPrice(order.shipping_fee) %></span>
      </div>
      <div class="flex justify-between text-base font-bold pt-3 border-t border-[#F2EFE9]">
        <span>Tổng cộng:</span>
        <span class="text-[#C2410C]"><%= formatPrice(order.total_amount) %></span>
      </div>
    </div>
  </div>

  <!-- Action -->
  <div class="text-center">
    <a href="/" class="px-8 py-4 bg-[#1A1918] hover:bg-[#D4A373] text-white font-medium tracking-wide rounded-xl shadow-lg transition duration-300 inline-block">
      Tiếp tục mua sắm
    </a>
  </div>

</div>

<%- include('partials/footer') %>
